<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ConfigOverridesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/override_notes"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Switch
            android:id="@+id/switchPersist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/persist_after_reboot"
            android:paddingVertical="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/persist_after_reboot_summary"
            android:textSize="12sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:dividerHorizontal"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="?android:textColorPrimary"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnEnableAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enable_all_features"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnResetConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_config"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/status_title"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textStatusVolte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatusNrSa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatusVonr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatusWfc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatus5gThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatusSignalInflate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatusImsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

        <TextView
            android:id="@+id/textStatusShow4g"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:text="@string/initializing" />

    </LinearLayout>

</ScrollView>